name = ca-certificates
version = 2024.12.31
category = networking
description = Common CA certificates
homepage = https://wiki.mozilla.org/CA
license = MPL-2.0
epoch = 0
release = 1
build_style = custom

source =
    https://curl.se/ca/cacert-2024-12-31.pem    

install_cmds =
    mkdir -p {{PREFIX}}/etc/ssl/certs
    cp cacert-2024-12-31.pem {{PREFIX}}/etc/ssl/certs/ca-certificates.crt
    ln -sf ca-certificates.crt {{PREFIX}}/etc/ssl/certs/ca-bundle.crt

depends =


makedepends =

